rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- REUSABLE PRIMITIVES & HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn(); // Allow standard authenticated SaaS sessions
    }

    function isOwner(ownerId) {
      return isSignedIn() && request.auth.uid == ownerId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function isValidUserId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- VALIDATION BLUEPRINTS ---

    function isValidUser(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.role in ['Owner', 'Admin', 'Editor', 'Viewer']
        && data.keys().hasAll(['id', 'name', 'email', 'role']);
    }

    function isValidCSVFile(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 255
        && data.size is int && data.size >= 0 && data.size <= 26214400
        && data.uploadedAt is string
        && data.status in ['pending', 'auditing', 'completed', 'failed']
        && data.score is int && data.score >= 0 && data.score <= 100
        && data.headers is list
        && data.rows is list
        && data.ownerId is string
        && data.issues is list
        && data.keys().hasAll(['id', 'name', 'size', 'uploadedAt', 'status', 'score', 'headers', 'rows', 'ownerId', 'issues']);
    }

    function isValidAuditActivity(data) {
      return data.id is string && data.id.size() <= 128
        && data.userId is string && data.userId.size() <= 128
        && data.userName is string && data.userName.size() <= 200
        && data.action is string && data.action.size() <= 1000
        && data.timestamp is string
        && data.keys().hasAll(['id', 'userId', 'userName', 'action', 'timestamp']);
    }

    function isValidTeamMember(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.role in ['Owner', 'Admin', 'Editor', 'Viewer']
        && data.status in ['active', 'invited']
        && data.keys().hasAll(['id', 'name', 'email', 'role', 'status']);
    }

    function isValidDraft(data) {
      return data.userId is string && data.userId.size() <= 128
        && data.mappings is map
        && data.explanations is map
        && data.updatedAt is string
        && data.keys().hasAll(['userId', 'mappings', 'explanations', 'updatedAt']);
    }

    // --- COLLECTION MATCH BLOCKS ---

    // USERS COLLECTION
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId) && isValidUserId(userId);
      allow list: if isSignedIn();
      allow create: if isVerified() && (request.auth.uid == userId) && isValidUserId(userId) && isValidUser(incoming());
      allow update: if isVerified() && (request.auth.uid == userId) && isValidUserId(userId) && isValidUser(incoming())
        && incoming().role == existing().role; // Role remains immutable on self-edit
      allow delete: if false;
    }

    // FILES COLLECTION
    match /files/{fileId} {
      allow get: if isSignedIn() && isValidId(fileId) && (isOwner(existing().ownerId) || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Owner', 'Admin', 'Editor', 'Viewer']);
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['Owner', 'Admin', 'Editor', 'Viewer']);
      allow create: if isVerified() && isValidId(fileId) && isOwner(incoming().ownerId) && isValidCSVFile(incoming());
      allow update: if isVerified() && isValidId(fileId) && isOwner(existing().ownerId) && isValidCSVFile(incoming())
        && incoming().ownerId == existing().ownerId;
      allow delete: if isVerified() && isValidId(fileId) && isOwner(existing().ownerId);
    }

    // ACTIVITIES TIMELINE
    match /activities/{activityId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(activityId) && (request.auth.uid == incoming().userId || incoming().userId.startsWith('usr-')) && isValidAuditActivity(incoming());
      allow update, delete: if false; // Timeline is immutable append-only ledger
    }

    // MEMBERS COLLECTION
    match /members/{memberId} {
      allow read: if isSignedIn();
      allow create: if isVerified() && isValidId(memberId) && isValidTeamMember(incoming());
      allow update: if isVerified() && isValidId(memberId) && isValidTeamMember(incoming());
      allow delete: if isVerified() && isValidId(memberId);
    }

    // DRAFTS COLLECTION
    match /drafts/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list: if false;
      allow create, update: if isSignedIn() && request.auth.uid == userId;
      allow delete: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
